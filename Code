)
fun getTodayStr(): String = LocalDate.now().toString()
fun getDayName(dateStr: String): String = try { LocalDate.parse(dateStr).dayOfWeek.name.lowercase().replaceFirstChar { it.uppercase() } } catch(e:Exception){ "Backlog" }
fun getDatesOfCurrentWeek(): List<String> { var sunday = LocalDate.now(); while (sunday.dayOfWeek != DayOfWeek.SUNDAY) sunday = sunday.minusDays(1); return (0..6).map { sunday.plusDays(it.toLong()).toString() } }
fun formatTime(seconds: Long): String = String.format(Locale.getDefault(), "%02d:%02d:%02d", seconds / 3600, (seconds % 3600) / 60, seconds % 60)
fun calculateHabitStreak(completedDates: Set<String>): Int { if (completedDates.isEmpty()) return 0; val today = LocalDate.now(); val yesterday = today.minusDays(1); if (!completedDates.contains(today.toString()) && !completedDates.contains(yesterday.toString())) return 0; var streak = 0; var currentDate = if (completedDates.contains(today.toString())) today else yesterday; while (completedDates.contains(currentDate.toString())) { streak++; currentDate = currentDate.minusDays(1) }; return streak }

fun getDaysRemaining(deadlineStr: String?): String? {
    if (deadlineStr.isNullOrBlank()) return null
    return try {
        val deadline = LocalDate.parse(deadlineStr)
        val today = LocalDate.now()
        val diff = java.time.temporal.ChronoUnit.DAYS.between(today, deadline)
        when {
            diff < 0 -> "Overdue by ${kotlin.math.abs(diff)} days"
            diff == 0L -> "Due Today!"
            else -> "$diff days left"
        }
    } catch (e: Exception) { null }
}

fun sendSassyWaddlesNotification(context: Context, progress: Int, maxStreak: Int) {
    val channelId = "waddles_wav_channel_v1"
    val notificationManager = context.getSystemService(Context.NOTIFICATION_SERVICE) as NotificationManager
    val soundUri = Uri.parse("android.resource://${context.packageName}/${R.raw.quack}")

    if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
        val channel = NotificationChannel(channelId, "Waddles Notifications", NotificationManager.IMPORTANCE_HIGH).apply { description = "Sassy motivation from your duck"; val audioAttributes = AudioAttributes.Builder().setContentType(AudioAttributes.CONTENT_TYPE_SONIFICATION).setUsage(AudioAttributes.USAGE_NOTIFICATION).build(); setSound(soundUri, audioAttributes); enableVibration(true) }
        notificationManager.createNotificationChannel(channel)
    }

    val message = when {
        progress == 0 -> listOf("It's getting late and you've done nothing. Quack your act together.", "Are we hibernating today? Get to work!", "I'm starving for productivity. Feed me some checked boxes!").random()
        progress == 100 -> listOf("Wow, 100%? You actually did it. I'm mildly impressed.", "All tasks complete! You may now bask in my duckly glory.", "Perfection. I always knew you were my favorite.").random()
        maxStreak >= 5 -> "You're on a $maxStreak-day streak! Don't let me down now."
        progress > 50 -> "Halfway there. Keep waddling forward!"
        else -> listOf("Stop scrolling and start doing.", "I'm watching you. Finish those tasks.", "A little effort goes a long way. Quack.").random()
    }

    val builder = NotificationCompat.Builder(context, channelId).setSmallIcon(android.R.drawable.ic_dialog_info).setContentTitle("🦆 Waddles says...").setContentText(message).setPriority(NotificationCompat.PRIORITY_HIGH).setSound(soundUri).setAutoCancel(true)
    notificationManager.notify(Random.nextInt(), builder.build())
}

