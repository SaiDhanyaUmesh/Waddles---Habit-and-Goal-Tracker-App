            }
        }
    }
}

@Composable
fun AnimatedDuck(mood: String, type: String) {
    val infiniteTransition = rememberInfiniteTransition(label = "duck")
    val duration = if (mood == "sleep") 3000 else 1500
    val yTarget = when (mood) { "sleep" -> 5f; "happy" -> -5f; "excited" -> -10f; else -> -20f }
    val yOffset by infiniteTransition.animateFloat(initialValue = 0f, targetValue = yTarget, animationSpec = infiniteRepeatable(animation = tween(duration / 2, easing = FastOutSlowInEasing), repeatMode = RepeatMode.Reverse), label = "y")
    val rotationTarget = if (mood == "excited") 5f else 0f
    val rotation by infiniteTransition.animateFloat(initialValue = -rotationTarget, targetValue = rotationTarget, animationSpec = infiniteRepeatable(animation = tween(duration / 4, easing = LinearEasing), repeatMode = RepeatMode.Reverse), label = "rot")
    val scaleTarget = if (mood == "sleep") 0.98f else 1f
    val scale by infiniteTransition.animateFloat(initialValue = 1f, targetValue = scaleTarget, animationSpec = infiniteRepeatable(animation = tween(duration / 2), repeatMode = RepeatMode.Reverse), label = "scale")

    Box(modifier = Modifier.size(100.dp).graphicsLayer { translationY = yOffset.dp.toPx(); rotationZ = rotation; scaleX = scale; scaleY = scale }) {
        Canvas(modifier = Modifier.fillMaxSize()) {
            val w = size.width; val h = size.height
            val headColor = Color(0xFF65A046); val bodyColor = Color(0xFFA26653); val wingColor = Color(0xFF754030); val beakColor = Color(0xFFF58120)
            drawOval(color = Color.Black.copy(alpha = 0.1f), topLeft = Offset(w * 0.2f, h * 0.9f), size = Size(w * 0.6f, h * 0.1f))
            drawLine(beakColor, start = Offset(w * 0.45f, h * 0.8f), end = Offset(w * 0.45f, h * 0.95f), strokeWidth = 5f, cap = StrokeCap.Round)
            drawLine(beakColor, start = Offset(w * 0.45f, h * 0.95f), end = Offset(w * 0.35f, h * 0.95f), strokeWidth = 5f, cap = StrokeCap.Round)
            drawLine(beakColor, start = Offset(w * 0.6f, h * 0.8f), end = Offset(w * 0.6f, h * 0.95f), strokeWidth = 5f, cap = StrokeCap.Round)
            drawLine(beakColor, start = Offset(w * 0.6f, h * 0.95f), end = Offset(w * 0.5f, h * 0.95f), strokeWidth = 5f, cap = StrokeCap.Round)
            val bodyPath = Path().apply { moveTo(w * 0.35f, h * 0.85f); quadraticTo(w * 0.15f, h * 0.85f, w * 0.25f, h * 0.45f); quadraticTo(w * 0.4f, h * 0.45f, w * 0.55f, h * 0.45f); quadraticTo(w * 0.95f, h * 0.45f, w * 0.95f, h * 0.65f); quadraticTo(w * 1.0f, h * 0.7f, w * 0.9f, h * 0.75f); quadraticTo(w * 0.75f, h * 0.85f, w * 0.35f, h * 0.85f); close() }
            drawPath(bodyPath, bodyColor)
            val headPath = Path().apply { moveTo(w * 0.25f, h * 0.45f); lineTo(w * 0.25f, h * 0.25f); quadraticTo(w * 0.25f, h * 0.05f, w * 0.4f, h * 0.05f); quadraticTo(w * 0.55f, h * 0.05f, w * 0.55f, h * 0.25f); lineTo(w * 0.55f, h * 0.45f); quadraticTo(w * 0.4f, h * 0.45f, w * 0.25f, h * 0.45f); close() }
            drawPath(headPath, headColor)
            val collarPath = Path().apply { moveTo(w * 0.25f, h * 0.43f); quadraticTo(w * 0.4f, h * 0.46f, w * 0.55f, h * 0.43f); lineTo(w * 0.55f, h * 0.47f); quadraticTo(w * 0.4f, h * 0.5f, w * 0.25f, h * 0.47f); close() }
            drawPath(collarPath, Color.White)
            val wingPath = Path().apply { moveTo(w * 0.5f, h * 0.55f); quadraticTo(w * 0.8f, h * 0.5f, w * 0.85f, h * 0.6f); quadraticTo(w * 0.9f, h * 0.75f, w * 0.65f, h * 0.75f); quadraticTo(w * 0.45f, h * 0.7f, w * 0.5f, h * 0.55f); close() }
            drawPath(wingPath, wingColor)
            val beakPath = Path().apply { moveTo(w * 0.26f, h * 0.22f); quadraticTo(w * 0.05f, h * 0.22f, w * 0.05f, h * 0.26f); quadraticTo(w * 0.05f, h * 0.32f, w * 0.26f, h * 0.3f); close() }
            drawPath(beakPath, beakColor)
            drawLine(Color.Black.copy(alpha=0.5f), start = Offset(w * 0.08f, h * 0.26f), end = Offset(w * 0.24f, h * 0.26f), strokeWidth = 2f, cap = StrokeCap.Round)

            if (mood == "sleep") { val eyePath = Path().apply { moveTo(w * 0.32f, h * 0.2f); quadraticTo(w * 0.35f, h * 0.23f, w * 0.38f, h * 0.2f) }; drawPath(eyePath, color = Color.Black, style = Stroke(width = 3f, cap = StrokeCap.Round)) }
            else drawCircle(Color.Black, radius = w * 0.03f, center = Offset(w * 0.35f, h * 0.2f))

            if (type == "learning" || type == "habits") {
                val sproutPath = Path().apply { moveTo(w * 0.4f, h * 0.05f); quadraticTo(w * 0.4f, h * -0.05f, w * 0.45f, h * -0.1f) }; drawPath(path = sproutPath, color = Color(0xFF10B981), style = Stroke(width = 4f, cap = StrokeCap.Round))
                val leafPath = Path().apply { moveTo(w * 0.45f, h * -0.1f); quadraticTo(w * 0.55f, h * -0.15f, w * 0.6f, h * -0.1f); quadraticTo(w * 0.5f, h * -0.05f, w * 0.45f, h * -0.1f) }; drawPath(path = leafPath, color = Color(0xFF10B981))
            } else if (type == "weekly") {
                val bowPath = Path().apply { moveTo(w * 0.4f, h * 0.45f); lineTo(w * 0.3f, h * 0.35f); lineTo(w * 0.3f, h * 0.55f); close(); moveTo(w * 0.4f, h * 0.45f); lineTo(w * 0.5f, h * 0.35f); lineTo(w * 0.5f, h * 0.55f); close() }; drawPath(path = bowPath, color = Color(0xFFFBBF24)); drawCircle(Color.Yellow, radius = 6f, center = Offset(w * 0.4f, h * 0.45f))
            } else if (type == "achievements") {
                val crownPath = Path().apply { moveTo(w * 0.2f, h * 0.05f); lineTo(w * 0.25f, h * -0.15f); lineTo(w * 0.35f, h * -0.05f); lineTo(w * 0.45f, h * -0.2f); lineTo(w * 0.55f, h * -0.05f); lineTo(w * 0.65f, h * -0.15f); lineTo(w * 0.7f, h * 0.05f); close() }; drawPath(path = crownPath, color = Color(0xFFFBBF24))
            }
        }
    }
}

@Composable
fun ProgressBar(label: String, current: Int, total: Int, color: Color) {
    val percentage = if (total == 0) 0 else (current * 100 / total)
    Column(modifier = Modifier.fillMaxWidth()) {
        Row(modifier = Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceBetween) { Text(text = label.uppercase(), fontSize = 10.sp, fontWeight = FontWeight.Bold, color = Color.Black); Text(text = "$percentage%", fontSize = 10.sp, fontWeight = FontWeight.Bold, color = Color.Black) }
        Spacer(modifier = Modifier.height(6.dp))
        Box(modifier = Modifier.fillMaxWidth().height(8.dp).clip(CircleShape).background(Color(0xFFE4E4E7))) { Box(modifier = Modifier.fillMaxHeight().fillMaxWidth(percentage / 100f).clip(CircleShape).background(color)) }
    }
}

@Composable
fun CategoryPieChart(data: Map<Category, Float>, modifier: Modifier = Modifier) {
    val total = data.values.sum()
    if (total == 0f) { Box(modifier = modifier.background(Color(0xFFE4E4E7), CircleShape), contentAlignment = Alignment.Center) { Text("No Data", color = Color.Gray, fontSize = 12.sp, fontWeight = FontWeight.Bold) }; return }
    Canvas(modifier = modifier) {
        var startAngle = -90f
        data.forEach { (category, value) -> val sweepAngle = (value / total) * 360f; drawArc(color = getCategoryColor(category), startAngle = startAngle, sweepAngle = sweepAngle, useCenter = true, size = Size(size.width, size.height)); startAngle += sweepAngle }
    }
}

@Composable
fun WeeklyBarChart(timeLogs: List<TimeLog>) {
    val weekDates = getDatesOfCurrentWeek()
    val dailyTotals = weekDates.map { date -> date to timeLogs.filter { it.date == date }.map { it.hours }.sum() }
    val maxHours = dailyTotals.maxOfOrNull { it.second }?.coerceAtLeast(0.5f) ?: 0.5f

    Row(modifier = Modifier.fillMaxWidth().height(140.dp), horizontalArrangement = Arrangement.SpaceEvenly, verticalAlignment = Alignment.Bottom) {
        dailyTotals.forEach { (date, hours) ->
            val heightPercent = if (maxHours > 0) (hours / maxHours).coerceIn(0.02f, 1f) else 0.02f
            Column(horizontalAlignment = Alignment.CenterHorizontally, verticalArrangement = Arrangement.Bottom, modifier = Modifier.fillMaxHeight()) {
                Text(if (hours >= 0.05f) String.format(Locale.getDefault(), "%.1f", hours) else "", fontSize = 10.sp, color = Color.Gray)
                Spacer(modifier = Modifier.height(4.dp))
                Box(modifier = Modifier.width(28.dp).fillMaxHeight(heightPercent).clip(RoundedCornerShape(topStart = 6.dp, topEnd = 6.dp)).background(if (date == getTodayStr()) Color.Black else Color.LightGray))
                Spacer(modifier = Modifier.height(6.dp))
                Text(getDayName(date).take(3).uppercase(), fontSize = 10.sp, color = Color.Black, fontWeight = FontWeight.Bold)
            }
        }
    }
}

@Composable
fun WeeklyWrapUpDialog(timeLogs: List<TimeLog>, tasks: List<Task>, habits: List<Habit>, onDismiss: () -> Unit) {
    val weekDates = getDatesOfCurrentWeek()
    val weeklyLogs = timeLogs.filter { weekDates.contains(it.date) }; val weeklyTasks = tasks.filter { weekDates.contains(it.date) }
    val totalHours = weeklyLogs.map { it.hours }.sum()
    val completedTasks = weeklyTasks.count { it.completed }
    val totalHabitsMaintained = habits.count { calculateHabitStreak(it.completedDates) >= 3 }

    AlertDialog(
        onDismissRequest = onDismiss, containerColor = Color.White,
        title = { Text("🎉 Weekly Wrap-Up", fontWeight = FontWeight.Bold, color = Color.Black, fontSize = 24.sp) },
        text = {
            Column(verticalArrangement = Arrangement.spacedBy(16.dp)) {
                Text("Here is a summary of your legendary week:", color = Color.DarkGray)
                Card(colors = CardDefaults.cardColors(containerColor = Color(0xFFF4F4F5))) {
                    Column(modifier = Modifier.padding(16.dp).fillMaxWidth(), verticalArrangement = Arrangement.spacedBy(12.dp)) {
                        Row(horizontalArrangement = Arrangement.SpaceBetween, modifier = Modifier.fillMaxWidth()) { Text("⏱️ Focus Time:", fontWeight = FontWeight.Bold, color = Color.Black); Text(String.format(Locale.getDefault(), "%.1f hrs", totalHours), color = Color.Black) }
                        Row(horizontalArrangement = Arrangement.SpaceBetween, modifier = Modifier.fillMaxWidth()) { Text("✅ Tasks Conquered:", fontWeight = FontWeight.Bold, color = Color.Black); Text("$completedTasks", color = Color.Black) }
                        Row(horizontalArrangement = Arrangement.SpaceBetween, modifier = Modifier.fillMaxWidth()) { Text("🔥 Habits Maintained:", fontWeight = FontWeight.Bold, color = Color.Black); Text("$totalHabitsMaintained", color = Color.Black) }
                    }
                }
                if (totalHours > 10) Text("Incredible focus this week! Waddles is proud.", color = Color(0xFF10B981), fontWeight = FontWeight.Bold, textAlign = TextAlign.Center, modifier = Modifier.fillMaxWidth())
                else Text("A solid foundation. Let's build on this next week!", color = Color(0xFFF58120), fontWeight = FontWeight.Bold, textAlign = TextAlign.Center, modifier = Modifier.fillMaxWidth())
            }
        },
        confirmButton = { Button(onClick = onDismiss, colors = ButtonDefaults.buttonColors(containerColor = Color.Black)) { Text("Close", color = Color.White) } }
    )
}

