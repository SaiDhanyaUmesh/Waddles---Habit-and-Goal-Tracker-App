    val (title, subtitle, mood, progressColor) = when (type) {
        "weekly" -> listOf("Weekly Waddles is waiting...", "Let's make this week legendary!", "excited", Color.Black)
        "learning" -> listOf("Goals Waddles is growing...", "Ready to crush those big projects?", "happy", Color.Black)
