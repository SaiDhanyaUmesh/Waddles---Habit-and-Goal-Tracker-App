                            Button(onClick = { viewModel.isPomodoro = true }, colors = ButtonDefaults.buttonColors(containerColor = if (viewModel.isPomodoro) Color.Black else Color.Transparent)) { Text("Pomodoro (25m)", color = if (viewModel.isPomodoro) Color.White else Color.Gray) }
                        }
                    }

                    Spacer(modifier = Modifier.height(16.dp))
                    val displaySecs = if (viewModel.isPomodoro) (1500L - viewModel.elapsedSeconds).coerceAtLeast(0L) else viewModel.elapsedSeconds
                    Text(text = formatTime(displaySecs), fontSize = 56.sp, fontWeight = FontWeight.Black, color = if (viewModel.isTimerRunning) getCategoryColor(displayCategory) else Color.Black, fontFamily = androidx.compose.ui.text.font.FontFamily.Monospace)

                    val handleSaveAttempt: (Boolean) -> Unit = { markTaskComplete ->
                        if (viewModel.elapsedSeconds < 300L) { showCheaterDialog = true } else {
                            viewModel.addTimeLog(displayCategory, viewModel.elapsedSeconds / 3600f)
                            if (activeTask != null && markTaskComplete) viewModel.toggleTask(activeTask.id)
                            viewModel.resetTimer()
                            showSaveForm = false
                        }
                    }

                    if (activeTask != null) {
                        Row(horizontalArrangement = Arrangement.spacedBy(16.dp)) {
                            if (viewModel.elapsedSeconds == 0L && !viewModel.isTimerRunning) { Button(onClick = { viewModel.toggleTimer(true, context) }, colors = ButtonDefaults.buttonColors(containerColor = Color(0xFF10B981))) { Text("START", color = Color.White, fontWeight = FontWeight.Bold) }; Button(onClick = { viewModel.activeTaskId = null }, colors = ButtonDefaults.buttonColors(containerColor = Color.LightGray)) { Text("CANCEL", color = Color.Black) } }
                            else if (viewModel.isTimerRunning) { Button(onClick = { viewModel.toggleTimer(false, context) }, colors = ButtonDefaults.buttonColors(containerColor = Color(0xFFF59E0B))) { Text("PAUSE", color = Color.White) }; Button(onClick = { handleSaveAttempt(true) }, colors = ButtonDefaults.buttonColors(containerColor = Color.Black)) { Text("COMPLETE TASK", color = Color.White) } }
                            else { Button(onClick = { viewModel.toggleTimer(true, context) }, colors = ButtonDefaults.buttonColors(containerColor = Color(0xFF10B981))) { Text("RESUME", color = Color.White) }; Button(onClick = { handleSaveAttempt(true) }, colors = ButtonDefaults.buttonColors(containerColor = Color.Black)) { Text("COMPLETE TASK", color = Color.White) }; Button(onClick = { viewModel.resetTimer() }, colors = ButtonDefaults.buttonColors(containerColor = Color.LightGray)) { Text("QUIT", color = Color.Black) } }
                        }
                    } else {
                        AnimatedVisibility(visible = !showSaveForm) {
                            Row(horizontalArrangement = Arrangement.spacedBy(16.dp)) {
                                if (viewModel.elapsedSeconds == 0L && !viewModel.isTimerRunning) Button(onClick = { viewModel.toggleTimer(true, context) }, colors = ButtonDefaults.buttonColors(containerColor = Color(0xFF10B981))) { Text("START", color = Color.White, fontWeight = FontWeight.Bold) }
                                else if (viewModel.isTimerRunning) { Button(onClick = { viewModel.toggleTimer(false, context) }, colors = ButtonDefaults.buttonColors(containerColor = Color(0xFFF59E0B))) { Text("PAUSE", color = Color.White) }; Button(onClick = { viewModel.toggleTimer(false, context); showSaveForm = true }, colors = ButtonDefaults.buttonColors(containerColor = Color.Black)) { Text("STOP & SAVE", color = Color.White) } }
                                else { Button(onClick = { viewModel.resetTimer() }, colors = ButtonDefaults.buttonColors(containerColor = Color.LightGray)) { Text("RESET", color = Color.Black) }; Button(onClick = { viewModel.toggleTimer(true, context) }, colors = ButtonDefaults.buttonColors(containerColor = Color(0xFF10B981))) { Text("RESUME", color = Color.White) }; Button(onClick = { showSaveForm = true }, colors = ButtonDefaults.buttonColors(containerColor = Color.Black)) { Text("SAVE", color = Color.White) } }
                            }
                        }
                        AnimatedVisibility(visible = showSaveForm) {
                            Column(verticalArrangement = Arrangement.spacedBy(8.dp), modifier = Modifier.fillMaxWidth().background(Color(0xFFFAFAFA), RoundedCornerShape(8.dp)).padding(16.dp)) {
                                Row(modifier = Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.Center, verticalAlignment = Alignment.CenterVertically) { TextButton(onClick = { showSaveForm = false }) { Text("Cancel", color = Color.Gray) }; Spacer(modifier = Modifier.width(8.dp)); Button(onClick = { handleSaveAttempt(false) }, colors = ButtonDefaults.buttonColors(containerColor = Color.Black)) { Text("LOG SESSION", color = Color.White) } }
                            }
                        }
                    }
                }
            }
        }
        item { Text("This Week's Focus", fontWeight = FontWeight.Bold, fontSize = 20.sp, color = Color.Black); Card(colors = CardDefaults.cardColors(containerColor = Color.White), modifier = Modifier.fillMaxWidth().padding(top = 8.dp)) { Column(modifier = Modifier.padding(16.dp)) { WeeklyBarChart(timeLogs = timeLogs) } } }
        item { Text("Monthly Breakdown", fontWeight = FontWeight.Bold, fontSize = 20.sp, color = Color.Black); Card(colors = CardDefaults.cardColors(containerColor = Color.White), modifier = Modifier.fillMaxWidth().padding(top = 8.dp)) { Row(modifier = Modifier.padding(24.dp).fillMaxWidth(), verticalAlignment = Alignment.CenterVertically) { CategoryPieChart(data = monthlyCategoryTotals, modifier = Modifier.size(120.dp)); Spacer(modifier = Modifier.width(24.dp)); Column(verticalArrangement = Arrangement.spacedBy(8.dp)) { Category.entries.forEach { cat -> Row(verticalAlignment = Alignment.CenterVertically) { Box(modifier = Modifier.size(12.dp).clip(CircleShape).background(getCategoryColor(cat))); Spacer(modifier = Modifier.width(8.dp)); Text(cat.name, fontSize = 12.sp, color = Color.Black) } } } } } }
        item { Text("Yearly Breakdown", fontWeight = FontWeight.Bold, fontSize = 20.sp, color = Color.Black); Card(colors = CardDefaults.cardColors(containerColor = Color.White), modifier = Modifier.fillMaxWidth().padding(top = 8.dp)) { Column(modifier = Modifier.padding(24.dp).fillMaxWidth()) { Row(modifier = Modifier.fillMaxWidth(), verticalAlignment = Alignment.CenterVertically) { CategoryPieChart(data = yearlyCategoryTotals, modifier = Modifier.size(120.dp)); Spacer(modifier = Modifier.width(24.dp)); Column(verticalArrangement = Arrangement.spacedBy(8.dp)) { Category.entries.forEach { cat -> Row(verticalAlignment = Alignment.CenterVertically) { Box(modifier = Modifier.size(12.dp).clip(CircleShape).background(getCategoryColor(cat))); Spacer(modifier = Modifier.width(8.dp)); Text(cat.name, fontSize = 12.sp, color = Color.Black) } } } }; Spacer(modifier = Modifier.height(24.dp)); Button(onClick = { showYearlyLogsDialog = true }, modifier = Modifier.fillMaxWidth(), colors = ButtonDefaults.buttonColors(containerColor = Color.Black)) { Text("View Yearly Log History", color = Color.White, fontWeight = FontWeight.Bold) } } } }
    }
}

@Composable
