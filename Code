// --- Room Database & Entities ---

enum class Category { Fitness, Learning, Hobbies, Miscellaneous }

fun getCategoryColor(category: Category): Color = when (category) {
    Category.Fitness -> Color(0xFFEF4444)
    Category.Learning -> Color(0xFF3B82F6)
    Category.Hobbies -> Color(0xFF10B981)
    Category.Miscellaneous -> Color(0xFF9CA3AF)
}

@Entity(tableName = "tasks")
data class Task(@PrimaryKey val id: String = UUID.randomUUID().toString(), val text: String, val completed: Boolean = false, val category: Category, val date: String, val learningItemId: String? = null, val learningUnits: Int = 1)

@Entity(tableName = "learning_items")
data class LearningItem(@PrimaryKey val id: String = UUID.randomUUID().toString(), val title: String, val totalUnits: Int, val completedUnits: Int = 0, val type: String, val category: Category? = Category.Learning, val deadline: String? = null)

@Entity(tableName = "time_logs")
data class TimeLog(@PrimaryKey val id: String = UUID.randomUUID().toString(), val date: String, val category: Category, val hours: Float)

@Entity(tableName = "habits")
data class Habit(@PrimaryKey val id: String = UUID.randomUUID().toString(), val name: String, val completedDates: Set<String> = emptySet())

class Converters {
    private val gson = Gson()
    @TypeConverter fun fromCategory(category: Category?): String? = category?.name
    @TypeConverter fun toCategory(name: String?): Category? = name?.let { Category.valueOf(it) }
    @TypeConverter fun fromStringSet(set: Set<String>): String = gson.toJson(set)
    @TypeConverter fun toStringSet(data: String): Set<String> = gson.fromJson(data, object : TypeToken<Set<String>>() {}.type)
}

@Dao
interface WaddlesDao {
    @Query("SELECT * FROM tasks") fun getTasks(): Flow<List<Task>>
    @Query("SELECT * FROM tasks WHERE id = :id") suspend fun getTaskById(id: String): Task?
    @Insert(onConflict = OnConflictStrategy.REPLACE) suspend fun insertTask(task: Task)
    @Update suspend fun updateTask(task: Task)
    @Query("DELETE FROM tasks WHERE id = :id") suspend fun deleteTask(id: String)

    @Query("SELECT * FROM learning_items") fun getLearningItems(): Flow<List<LearningItem>>
    @Query("SELECT * FROM learning_items WHERE id = :id") suspend fun getLearningItemById(id: String): LearningItem?
    @Insert(onConflict = OnConflictStrategy.REPLACE) suspend fun insertLearningItem(item: LearningItem)
    @Update suspend fun updateLearningItem(item: LearningItem)

    @Query("SELECT * FROM time_logs") fun getTimeLogs(): Flow<List<TimeLog>>
    @Insert(onConflict = OnConflictStrategy.REPLACE) suspend fun insertTimeLog(log: TimeLog)

    @Query("SELECT * FROM habits") fun getHabits(): Flow<List<Habit>>
    @Query("SELECT * FROM habits WHERE id = :id") suspend fun getHabitById(id: String): Habit?
    @Insert(onConflict = OnConflictStrategy.REPLACE) suspend fun insertHabit(habit: Habit)
    @Update suspend fun updateHabit(habit: Habit)
    @Query("DELETE FROM habits WHERE id = :id") suspend fun deleteHabit(id: String)
}

@Database(entities = [Task::class, LearningItem::class, TimeLog::class, Habit::class], version = 1, exportSchema = false)
@TypeConverters(Converters::class)
abstract class WaddlesDatabase : RoomDatabase() {
    abstract fun waddlesDao(): WaddlesDao
    companion object {
        @Volatile private var INSTANCE: WaddlesDatabase? = null
        fun getDatabase(context: Context): WaddlesDatabase = INSTANCE ?: synchronized(this) {
            Room.databaseBuilder(context.applicationContext, WaddlesDatabase::class.java, "waddles_db").build().also { INSTANCE = it }
        }
    }
}

// --- ViewModel ---

class WaddlesViewModel(private val dao: WaddlesDao) : ViewModel() {
    val tasks: StateFlow<List<Task>> = dao.getTasks().stateIn(viewModelScope, SharingStarted.Lazily, emptyList())
    val learningItems: StateFlow<List<LearningItem>> = dao.getLearningItems().stateIn(viewModelScope, SharingStarted.Lazily, emptyList())
    val timeLogs: StateFlow<List<TimeLog>> = dao.getTimeLogs().stateIn(viewModelScope, SharingStarted.Lazily, emptyList())
    val habits: StateFlow<List<Habit>> = dao.getHabits().stateIn(viewModelScope, SharingStarted.Lazily, emptyList())

    var isTimerRunning by mutableStateOf(false)
        private set
    var elapsedSeconds by mutableLongStateOf(0L)
        private set
    var activeTaskId by mutableStateOf<String?>(null)
    var activeTimerCategory by mutableStateOf(Category.Learning)
    var isPomodoro by mutableStateOf(false)

    private var startTime = 0L
    private var accumulatedTime = 0L
    private var timerJob: Job? = null

    fun toggleTimer(start: Boolean, context: Context) {
        isTimerRunning = start
        if (start) {
            startTime = System.currentTimeMillis()
            timerJob = viewModelScope.launch {
                while (isActive) {
                    val now = System.currentTimeMillis()
                    elapsedSeconds = accumulatedTime + (now - startTime) / 1000
                    if (isPomodoro && elapsedSeconds >= 1500L) {
                        isTimerRunning = false
                        sendSassyWaddlesNotification(context, 100, 5)
                        timerJob?.cancel()
                    }
                    delay(500)
                }
            }
        } else {
            accumulatedTime = elapsedSeconds
            timerJob?.cancel()
        }
    }

    fun resetTimer() {
        timerJob?.cancel()
        isTimerRunning = false
        accumulatedTime = 0L
        elapsedSeconds = 0L
        activeTaskId = null
    }

    fun toggleTask(taskId: String) {
        viewModelScope.launch {
            val task = dao.getTaskById(taskId) ?: return@launch
            val newCompleted = !task.completed
            if (task.learningItemId != null && task.learningUnits > 0) {
                val item = dao.getLearningItemById(task.learningItemId)
                if (item != null) {
                    val change = if (newCompleted) task.learningUnits else -task.learningUnits
                    dao.updateLearningItem(item.copy(completedUnits = (item.completedUnits + change).coerceAtLeast(0)))
                }
            }
            dao.updateTask(task.copy(completed = newCompleted))
        }
    }

    fun addTask(text: String, category: Category, date: String, learningId: String?, units: Int) {
        if (text.isNotBlank()) viewModelScope.launch { dao.insertTask(Task(text = text, category = category, date = date, learningItemId = learningId, learningUnits = units)) }
    }

    fun deleteTask(id: String) {
        viewModelScope.launch {
            val task = dao.getTaskById(id)
            if (task != null && task.completed && task.learningItemId != null && task.learningUnits > 0) {
                val item = dao.getLearningItemById(task.learningItemId)
                if (item != null) dao.updateLearningItem(item.copy(completedUnits = (item.completedUnits - task.learningUnits).coerceAtLeast(0)))
            }
            dao.deleteTask(id)
        }
    }

    fun addTimeLog(category: Category, hours: Float) {
        viewModelScope.launch { dao.insertTimeLog(TimeLog(date = getTodayStr(), category = category, hours = hours)) }
    }

    fun addLearningItem(title: String, total: Int, type: String, cat: Category, deadline: String?) {
        viewModelScope.launch { dao.insertLearningItem(LearningItem(title = title, totalUnits = total, type = type, category = cat, deadline = deadline)) }
    }

    fun addLearningProgress(itemId: String) {
        viewModelScope.launch { val item = dao.getLearningItemById(itemId); if (item != null && item.completedUnits < item.totalUnits) dao.updateLearningItem(item.copy(completedUnits = item.completedUnits + 1)) }
    }

    fun addHabit(name: String) {
        if (name.isNotBlank()) viewModelScope.launch { dao.insertHabit(Habit(name = name)) }
    }

    fun toggleHabit(habitId: String, dateStr: String) {
        viewModelScope.launch { val h = dao.getHabitById(habitId); if (h != null) { val newDates = if (h.completedDates.contains(dateStr)) h.completedDates - dateStr else h.completedDates + dateStr; dao.updateHabit(h.copy(completedDates = newDates)) } }
    }

    fun deleteHabit(id: String) { viewModelScope.launch { dao.deleteHabit(id) } }
}

class WaddlesViewModelFactory(private val dao: WaddlesDao) : ViewModelProvider.Factory {
    override fun <T : ViewModel> create(modelClass: Class<T>): T {
        if (modelClass.isAssignableFrom(WaddlesViewModel::class.java)) @Suppress("UNCHECKED_CAST") return WaddlesViewModel(dao) as T
        throw IllegalArgumentException("Unknown ViewModel class")
    }
}

// --- Entry Point & Worker ---

class MainActivity : ComponentActivity() {
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        val workRequest = PeriodicWorkRequestBuilder<WaddlesWorker>(2, TimeUnit.HOURS).build()
        WorkManager.getInstance(this).enqueueUniquePeriodicWork("WaddlesRoutineTracker", ExistingPeriodicWorkPolicy.KEEP, workRequest)

        val database = WaddlesDatabase.getDatabase(this)

        setContent {
            val viewModel: WaddlesViewModel = viewModel(factory = WaddlesViewModelFactory(database.waddlesDao()))
            WaddlesApp(viewModel)
        }
    }
}

class WaddlesWorker(appContext: Context, workerParams: WorkerParameters) : CoroutineWorker(appContext, workerParams) {
    override suspend fun doWork(): Result {
        val dao = WaddlesDatabase.getDatabase(applicationContext).waddlesDao()
        val tasks = dao.getTasks().first()
        val habits = dao.getHabits().first()

        val todayStr = LocalDate.now().toString()
        val dailyTasks = tasks.filter { it.date == todayStr }
        val progress = if (dailyTasks.isEmpty()) 0 else (dailyTasks.count { it.completed } * 100 / dailyTasks.size)
        val maxStreak = habits.maxOfOrNull { calculateHabitStreak(it.completedDates) } ?: 0

        val currentHour = Calendar.getInstance().get(Calendar.HOUR_OF_DAY)
        if (currentHour in 8..21) sendSassyWaddlesNotification(applicationContext, progress, maxStreak)
        return Result.success()
    }
}

