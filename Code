val MOTIVATIONAL_QUOTES = listOf(
    Quote("You have a right to perform your prescribed duty, but you are not entitled to the fruits of action.", "Bhagavad Gita"),
    Quote("The two most powerful warriors are patience and time.", "Leo Tolstoy"),
    Quote("The journey of a thousand miles begins with a single step.", "Lao Tzu"),
    Quote("To go wrong in one's own way is better than to go right in someone else's.", "Fyodor Dostoevsky"),
    Quote("It does not matter how slowly you go as long as you do not stop.", "Confucius"),
