@Composable
fun DailyView(tasks: List<Task>, habits: List<Habit>, selectedDate: String, onSelectedDateChange: (String) -> Unit, toggleTask: (String) -> Unit, deleteTask: (String) -> Unit, addTask: (String, Category, String, String?, Int) -> Unit) {
    val dailyTasks = tasks.filter { it.date == selectedDate }
    val progress = if (dailyTasks.isEmpty()) 0 else (dailyTasks.count { it.completed } * 100 / dailyTasks.size)
    val quote = MOTIVATIONAL_QUOTES[(LocalDate.parse(selectedDate).dayOfYear) % MOTIVATIONAL_QUOTES.size]
    var newMiscTask by remember { mutableStateOf("") }
    val context = LocalContext.current

    LazyColumn(modifier = Modifier.fillMaxSize().padding(16.dp), verticalArrangement = Arrangement.spacedBy(24.dp)) {
        item {
            Row(modifier = Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceBetween, verticalAlignment = Alignment.CenterVertically) {
                Column { Text(getDayName(selectedDate), fontSize = 28.sp, fontWeight = FontWeight.Bold, color = Color.Black); Text(LocalDate.parse(selectedDate).format(DateTimeFormatter.ofPattern("MMMM d")), color = Color.Black) }
                IconButton(onClick = { val maxStreak = habits.maxOfOrNull { calculateHabitStreak(it.completedDates) } ?: 0; sendSassyWaddlesNotification(context, progress, maxStreak) }, modifier = Modifier.background(Color.White, CircleShape)) { Text("🦆", fontSize = 20.sp) }
            }
        }
        item {
            Row(horizontalArrangement = Arrangement.spacedBy(8.dp)) {
                IconButton(onClick = { onSelectedDateChange(LocalDate.parse(selectedDate).minusDays(1).toString()) }) { Icon(Icons.AutoMirrored.Filled.KeyboardArrowLeft, contentDescription = "Previous Day", tint = Color.Black) }
                Button(onClick = { onSelectedDateChange(getTodayStr()) }, colors = ButtonDefaults.buttonColors(containerColor = Color.White)) { Text("Today", color = Color.Black) }
                IconButton(onClick = { onSelectedDateChange(LocalDate.parse(selectedDate).plusDays(1).toString()) }) { Icon(Icons.AutoMirrored.Filled.KeyboardArrowRight, contentDescription = "Next Day", tint = Color.Black) }
            }
        }
        item { Card(modifier = Modifier.fillMaxWidth(), colors = CardDefaults.cardColors(containerColor = Color.White)) { Column(modifier = Modifier.padding(16.dp)) { Text("\"${quote.text}\"", fontStyle = FontStyle.Italic, fontSize = 18.sp, textAlign = TextAlign.Center, modifier = Modifier.fillMaxWidth(), color = Color.Black); Text("— ${quote.author}", fontSize = 10.sp, fontWeight = FontWeight.Bold, color = Color.Black, modifier = Modifier.fillMaxWidth(), textAlign = TextAlign.Center) } } }
        item { Waddles(progress, "daily") }

        items(Category.entries) { category ->
            val categoryTasks = dailyTasks.filter { it.category == category }
            Column(verticalArrangement = Arrangement.spacedBy(8.dp)) {
                Text(category.name.uppercase(), fontSize = 12.sp, fontWeight = FontWeight.Bold, color = getCategoryColor(category), letterSpacing = 1.sp)
                Card(modifier = Modifier.fillMaxWidth(), colors = CardDefaults.cardColors(containerColor = Color.White)) {
                    Column(modifier = Modifier.padding(vertical = 8.dp)) {
                        if (categoryTasks.isEmpty() && category != Category.Miscellaneous) { Text("No tasks planned.", modifier = Modifier.padding(16.dp), color = Color.Black, fontStyle = FontStyle.Italic, fontSize = 14.sp) }
